[Unit]
Description=Clingy - Colorful sticky notes for your desktop
Documentation=https://github.com/nilsandgren/clingy
After=graphical-session.target

[Service]
Type=simple
ExecStart=%h/.local/share/clingy/venv/bin/python -m clingy.main
Environment=PYTHONPATH=%h/.local/share/clingy
WorkingDirectory=%h/.local/share/clingy
Restart=on-failure
RestartSec=3

[Install]
WantedBy=graphical-session.target
